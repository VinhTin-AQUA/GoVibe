{
  "ReverseProxy": {
    "Routes": {
      "mainRoute": {
        "ClusterId": "mainCluster",
        "Match": {
          "Path": "/main/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/main" },
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "searchingRoute": {
        "ClusterId": "searchingCluster",
        "Match": {
          "Path": "/searching/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/searching" },
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "authRoute": {
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/auth" },
          { "RequestHeaderOriginalHost": "true" }
        ]
      }
    },
    "Clusters": {
      "mainCluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7044/"
          }
        }
      },
      "searchingCluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7271/"
          }
        }
      },
      "authCluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7211/"
          }
        }
      }
    }
  }
}